{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": ["ES2022"],
      "outDir": "./dist/public",
      "rootDir": ".",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "allowJs": true
    },
    "include": [
      "server/**/*.ts",
      "shared/**/*.ts"
    ],
    "exclude": [
      "node_modules",
      "dist/public",
      "client"
    ]
  }