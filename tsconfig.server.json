{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": ["ES2022"],
      "outDir": "./dist",
      "rootDir": ".",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "allowJs": true,
      "declaration": false,
      "noEmit": false,
      "emitDeclarationOnly": false,
      "isolatedModules": true,
      "allowSyntheticDefaultImports": true
    },
    "include": [
      "server/**/*",
      "shared/**/*",
      "drizzle.config.ts",
      "vite.config.ts"
    ],
    "exclude": [
      "node_modules",
      "dist",
      "client",
      "**/*.test.ts"
    ]
  }